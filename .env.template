# ============================================================================
# AyntraCore – LOCAL CONFIG (.env)
# ============================================================================
# WARNUNG: Diese Datei enthält sensitive Daten!
# - Nicht in Git committen
# - Nicht mit anderen teilen
# - chmod 600 .env (nur Owner lesen)
#
# Siehe CREDENTIALS.md für detaillierte Setup-Anleitung
# ============================================================================

# ============================================================================
# DATABASE: Neon PostgreSQL (Credentials aus Neon Dashboard)
# ============================================================================

# Kopiere deine Connection String aus: https://console.neon.tech → Project → Database
# Format: postgresql://USER:PASSWORD@POOLER_HOST:5432/DATABASE?sslmode=require
# 
# ⚠️ WICHTIG: Nutze den POOLER-Host (mit "-pooler" im Namen)!
#
# Beispiel (NICHT REAL – verwende DEINE echten Werte):
# DATABASE_URL=postgresql://neondb_owner:npg_4LDepmQGJbT7@ep-raspy-bird-agdreweq-pooler.c-2.eu-central-1.aws.neon.tech:5432/neondb?sslmode=require

DATABASE_URL=postgresql://[DEIN_USER]:[DEIN_PASSWORD]@[DEIN_NEON_POOLER_HOST]:5432/neondb?sslmode=require

# ============================================================================
# KI-SERVICE: OpenRouter API Key (Credentials aus https://openrouter.ai/keys)
# ============================================================================

# Format: sk-or-v1-[lange-zeichenkette]
# Generiere einen neuen Key unter: https://openrouter.ai/keys
# Warning: Diese Keys haben Zugriff auf dein OpenRouter Budget!
#
# Beispiel (NICHT REAL):
# OPENROUTER_API_KEY=sk-or-v1-ab12cd34ef56gh78ij90kl12mn34op56qr78st90

OPENROUTER_API_KEY=sk-or-v1-[DEIN_API_KEY_HIER]

# ============================================================================
# SPRING BOOT PROFILE
# ============================================================================

# Wähle eines:
#   home   = Production Profile mit Neon PostgreSQL (nutzt DATABASE_URL)
#   school = Development Profile mit H2 In-Memory (ignoriert DATABASE_URL)

SPRING_PROFILES_ACTIVE=home

# ============================================================================
# DEBUG-MODUS (nur für Development!)
# ============================================================================

DEBUG=false
LOG_LEVEL=INFO

# ============================================================================
# SERVER
# ============================================================================

SERVER_PORT=8080
