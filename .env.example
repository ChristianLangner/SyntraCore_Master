# ============================================================================
# AyntraCore – Credentials & Configuration Template
# ============================================================================
# WICHTIG: Dies ist ein TEMPLATE. Kopiere diese Datei zu .env und fülle
# die echten Werte ein. Die Datei .env wird NICHT in Git versioniert!
#
# Für Development:
#   cp .env.example .env
#   # Dann echte Werte eintragen
#
# Für Production:
#   Nutze Environment Variables direkt (siehe Dokumentation)
# ============================================================================

# ============================================================================
# 1. DATENBANK (Neon PostgreSQL – Production Profile: home)
# ============================================================================

# Format: postgresql://user:password@host:port/database?sslmode=require
# Beispiel: postgresql://neondb_owner:npg_4LDepmQGJbT7@ep-raspy-bird-xxxxx-pooler.c-2.eu-central-1.aws.neon.tech:5432/neondb?sslmode=require
DATABASE_URL=postgresql://[USER]:[PASSWORD]@[NEON_ENDPOINT]:[PORT]/neondb?sslmode=require

# Alternativ: Einzelne Umgebungsvariablen
# PGHOST=ep-raspy-bird-xxxxx-pooler.c-2.eu-central-1.aws.neon.tech
# PGPORT=5432
# PGDATABASE=neondb
# PGUSER=neondb_owner
# PGPASSWORD=npg_4LDepmQGJbT7

# ============================================================================
# 2. KI-SERVICE (OpenRouter – DeepSeek API)
# ============================================================================

# OpenRouter API Key (für DeepSeek Modelle)
# Generiere auf: https://openrouter.ai/keys
# Format: sk-or-v1-[...long-string...]
OPENROUTER_API_KEY=sk-or-v1-___YOUR_KEY_HERE___

# Alternative: OpenAI Direct (falls gewünscht)
# OPENAI_API_KEY=sk-proj-[...]

# ============================================================================
# 3. SPRING BOOT PROFILE (lokal entwicklung – NICHT für Production!)
# ============================================================================

# Wähle: school (H2 In-Memory) oder home (Neon PostgreSQL)
SPRING_PROFILES_ACTIVE=home

# ============================================================================
# 4. DEBUG & LOGGING (nur für Development)
# ============================================================================

DEBUG=false
LOG_LEVEL=INFO

# ============================================================================
# 5. SERVER CONFIGURATION
# ============================================================================

# Server läuft auf Port 8080 (siehe application.properties)
SERVER_PORT=8080

# ============================================================================
# SICHERHEITSHINWEISE
# ============================================================================
# ✅ DO:
#   - .env in .gitignore eintragen (ist bereits done)
#   - Für Production: nur Environment Variables nutzen
#   - Secrets in Docker/Kubernetes Secrets Manager speichern
#   - Regelmäßig Credentials rotieren
#
# ❌ DON'T:
#   - .env zur Versionskontrolle hinzufügen
#   - Öffentlich auf GitHub committen
#   - In Properties-Dateien hardcoden
#   - In Logs ausgeben
